<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Join Us – Amba Bhavani Marata Mandali</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;700&family=Hind:wght@300;400;500&display=swap"
    rel="stylesheet" />
</head>

<body>

  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <img src="/images/logo.jpg" alt="ABM Logo" class="nav-logo-icon" style="object-fit: contain;">
        <div class="nav-logo-text">
          <span class="logo-main">Amba Bhavani</span>
          <span class="logo-sub">Marata Mandali</span>
        </div>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/gallery">Gallery</a>
        <a href="/committee">Committee</a>
        <a href="/join" class="active">Volunteer</a>
        <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" class="nav-join" target="_blank">Join WhatsApp</a>
      </div>
      <button class="hamburger" id="hamburger">&#9776;</button>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/">Home</a>
      <a href="/gallery">Gallery</a>
      <a href="/committee">Committee</a>
      <a href="/join">Volunteer</a>
      <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" target="_blank">Join WhatsApp</a>
    </div>
  </nav>

  <div class="page-hero">
    <div class="section-label" style="color: white;">Membership</div>
    <h1 class="page-title">Volunteer With Us</h1>
    <p class="page-desc">Join our dedicated team of volunteers and help make our events a success.</p>
  </div>

  <section class="section">
    <div class="section-inner" style="max-width: 600px; margin: 0 auto;">
      <div class="join-form-wrap">
        <% if (success) { %>
          <div class="success-box">
            <div class="success-icon">✅</div>
            <h3>Welcome, <%= name %>!</h3>
            <p>Your volunteer registration has been received! Please check your email for confirmation.</p>
            <a href="/" class="btn-primary" style="display:inline-block;margin-top:16px;">Back to Home</a>
          </div>
          <% } else { %>
            <form class="join-form" action="/join" method="POST">
              <h2>Volunteer Registration</h2>
              <p class="form-note">Sign up to help with upcoming events</p>
              <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" placeholder="Enter your full name" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" placeholder="+91 XXXXX XXXXX" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" />
              </div>
              <div class="form-group">
                <label for="address">Area / Locality *</label>
                <input type="text" id="address" name="address" placeholder="Your area or locality" required />
              </div>
              <div class="form-group">
                <label for="message">How would you like to help?</label>
                <textarea id="message" name="message" rows="3" placeholder="Tell us a bit about yourself..."></textarea>
              </div>
              <button type="submit" class="btn-primary large" style="width:100%;">Register to Volunteer</button>
            </form>
            <% } %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
</body>

</html>