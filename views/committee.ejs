<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Committee – Amba Bhavani Marata Mandali</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;700&family=Hind:wght@300;400;500&display=swap"
    rel="stylesheet" />
</head>

<body>

  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <img src="/images/logo.jpg" alt="ABM Logo" class="nav-logo-icon" style="object-fit: contain;">
        <div class="nav-logo-text">
          <span class="logo-main">Amba Bhavani</span>
          <span class="logo-sub">Marata Mandali</span>
        </div>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/gallery">Gallery</a>
        <a href="/committee" class="active">Committee</a>
        <a href="/join">Volunteer</a>
        <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" class="nav-join" target="_blank">Join WhatsApp</a>
      </div>
      <button class="hamburger" id="hamburger">&#9776;</button>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/">Home</a>
      <a href="/gallery">Gallery</a>
      <a href="/committee">Committee</a>
      <a href="/join">Volunteer</a>
      <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" target="_blank">Join WhatsApp</a>
    </div>
  </nav>

  <div class="page-hero">
    <div class="section-label" style="color: white;">Leadership</div>
    <h1 class="page-title">Our Committee</h1>
    <p class="page-desc">Dedicated leaders serving the Amba Bhavani Marata Mandali community with pride and devotion.
    </p>
  </div>

  <section class="section">
    <div class="section-inner">
      <div class="committee-grid">
        <% committee.forEach(member=> { %>
          <div class="committee-card">
            <div class="avatar" <%- `style="background:${member.bg}; color:${member.color};" ` %>>
              <% if (member.image) { %>
                <img src="<%= member.image %>" alt="<%= member.name %>">
                <% } else { %>
                  <%= member.initials %>
                    <% } %>
            </div>
            <h3>
              <%= member.name %>
            </h3>
            <p class="member-role">
              <%= member.role %>
            </p>
          </div>
          <% }) %>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="section-title">Want to serve the community?</h2>
      <p style="max-width:480px;margin:0 auto 28px;line-height:1.7;">Join us as a volunteer
        or active member and contribute to the growth of our community.</p>
      <a href="/join" class="btn-primary large">Join the Team</a>
    </div>
  </section>

  <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
</body>

</html>