<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Amba Bhavani Marata Mandali</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link
    href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;700&family=Hind:wght@300;400;500&display=swap"
    rel="stylesheet" />
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <div class="nav-logo-icon">ABM</div>
        <div class="nav-logo-text">
          <span class="logo-main">Amba Bhavani</span>
          <span class="logo-sub">Marata Mandali</span>
        </div>
      </a>
      <div class="nav-links">
        <a href="/" class="active">Home</a>
        <a href="/gallery">Gallery</a>
        <a href="/committee">Committee</a>
        <a href="/join">Volunteer</a>
        <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" class="nav-join" target="_blank">Join WhatsApp</a>
      </div>
      <button class="hamburger" id="hamburger">&#9776;</button>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/">Home</a>
      <a href="/gallery">Gallery</a>
      <a href="/committee">Committee</a>
      <a href="/join">Volunteer</a>
      <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" target="_blank">Join WhatsApp</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-tag">Est. Community Organization · BENGALURU</div>
      <h1 class="hero-title">Amba Bhavani<br />Marata Mandali</h1>
      <p class="hero-sub">Celebrating Culture, Unity &amp; Heritage</p>
      <p class="hero-desc">A proud community organization dedicated to preserving Maratha culture, celebrating our
        heritage, and serving our people with the spirit of Chhatrapati Shivaji Maharaj.</p>
      <div class="hero-btns">
        <a href="https://chat.whatsapp.com/YOUR_INVITE_LINK" class="btn-primary" target="_blank">Join WhatsApp Group</a>
        <a href="#events" class="btn-secondary">Upcoming Events</a>
      </div>
    </div>
    <div class="hero-emblem">
      <div class="emblem-ring">
        <div class="emblem-inner">
          <img src="https://voteforshivajijayanti.com/wp-content/uploads/2024/06/Chhatrapati-Shivaji-Maharaj-1.jpg"
            alt="Chhatrapati Shivaji Maharaj"
            style="width: 100%; height: 100%; object-fit: cover; object-position: top; border-radius: 50%;">
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-num">100+</span><span class="stat-label">Members</span></div>
    <div class="stat-item"><span class="stat-num">20+</span><span class="stat-label">Years of Service</span></div>
    <div class="stat-item"><span class="stat-num">50+</span><span class="stat-label">Events Organized</span></div>

  </div>

  <!-- VISION & MISSION -->
  <section class="section" id="mission">
    <div class="section-inner">
      <div class="section-label">Our Purpose</div>
      <h2 class="section-title">Vision &amp; Mission</h2>
      <p class="section-desc">Guided by the ideals of Chhatrapati Shivaji Maharaj — courage, justice, and service to the
        people.</p>
      <div class="vm-grid">
        <div class="vm-card">
          <div class="vm-icon" style="background:#ede9fe;">🎯</div>
          <h3>Our Vision</h3>
          <p>To be a leading Maratha community organization that fosters cultural pride, community welfare, and social
            harmony — carrying forward the legacy of Shivaji Maharaj across generations.</p>
        </div>
        <div class="vm-card">
          <div class="vm-icon" style="background:#fef3c7;">🙏</div>
          <h3>Our Mission</h3>
          <p>To unite Maratha community members, organize cultural and religious events, support members in need, and
            educate younger generations about our glorious heritage and traditions.</p>
        </div>
        <div class="vm-card">
          <div class="vm-icon" style="background:#d1fae5;">⚡</div>
          <h3>Our Values</h3>
          <p>Integrity, courage, community service, cultural preservation, and inclusive leadership — rooted in the
            Maratha warrior spirit and the blessings of Goddess Amba Bhavani.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SHIVAJI HISTORY -->
  <section class="shivaji-section">
    <div class="section-inner">
      <div class="shivaji-grid">
        <div class="shivaji-left">
          <div class="section-label" style="color:#f5c842;">Our Inspiration</div>
          <h2 class="section-title gold">Chhatrapati Shivaji Maharaj</h2>
          <p>Chhatrapati Shivaji Maharaj (1630–1680) was the founder of the Maratha Empire — a visionary king, fearless
            warrior, and compassionate ruler who liberated the Deccan from Mughal dominance.</p>
          <p>Born in Shivneri fort to Jijabai and Shahaji Bhonsle, he was inspired from childhood by his mother's
            stories of valor and the blessings of Goddess Bhavani. He built a powerful navy, established a just
            administration, and championed the rights of common people.</p>
          <p>His concept of <strong>"Swarajya"</strong> — self-rule — remains a timeless inspiration that every
            community deserves dignity, freedom, and self-determination.</p>
          <blockquote class="shivaji-quote">"Never bend your head, always hold it high. Look the world straight in the
            face."</blockquote>
        </div>
        <div class="shivaji-right">
          <div class="timeline">
            <div class="tl-item">
              <div class="tl-year">1630</div>
              <div>
                <h4>Birth at Shivneri Fort</h4>
                <p>Born to Jijabai and Shahaji Bhonsle. His mother instilled deep valor and devotion to Goddess Bhavani.
                </p>
              </div>
            </div>
            <div class="tl-item">
              <div class="tl-year">1645</div>
              <div>
                <h4>First Conquest — Torna Fort</h4>
                <p>At just 15, Shivaji captured Torna Fort, beginning his legendary Swarajya campaign.</p>
              </div>
            </div>
            <div class="tl-item">
              <div class="tl-year">1659</div>
              <div>
                <h4>Battle of Pratapgad</h4>
                <p>Defeated the powerful Afzal Khan, establishing Maratha supremacy in the Deccan.</p>
              </div>
            </div>
            <div class="tl-item">
              <div class="tl-year">1674</div>
              <div>
                <h4>Coronation at Raigad</h4>
                <p>Crowned as Chhatrapati — Emperor of the Marathas — at the grand Raigad Fort.</p>
              </div>
            </div>
            <div class="tl-item">
              <div class="tl-year">1680</div>
              <div>
                <h4>Eternal Legacy</h4>
                <p>His passing left an empire and an enduring spirit of Swarajya that inspires millions.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTS -->
  <section class="section" id="events">
    <div class="section-inner">
      <div class="section-label">What's Happening</div>
      <h2 class="section-title">Upcoming Events</h2>
      <p class="section-desc">Join us in celebrating our culture, traditions, and community milestones.</p>
      <div class="events-grid">
        <% events.forEach(event=> { %>
          <div class="event-card">
            <div class="event-header">
              <div class="event-date-box">
                <div class="event-day">
                  <%= event.day %>
                </div>
                <div class="event-month">
                  <%= event.month %>
                </div>
              </div>
              <span class="event-badge">
                <%= event.badge %>
              </span>
            </div>
            <div class="event-body">
              <h3>
                <%= event.title %>
              </h3>
              <p>
                <%= event.description %>
              </p>
              <div class="event-meta">
                <span>📍 <%= event.location %></span>
                <span>⏰ <%= event.time %></span>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
    </div>
  </section>

  <!-- UPDATES -->
  <section class="section updates-bg">
    <div class="section-inner">
      <div class="section-label">Stay Informed</div>
      <h2 class="section-title">Latest Updates</h2>
      <p class="section-desc">News and announcements from Amba Bhavani Marata Mandali.</p>
      <div class="updates-list">
        <% updates.forEach(update=> { %>
          <div class="update-item">
            <div class="update-dot" <%- `style="background-color: ${update.color};" ` %>></div>
            <div>
              <h4>
                <%= update.title %>
              </h4>
              <p>
                <%= update.description %>
              </p>
              <span class="update-time">
                <%= update.time %>
              </span>
            </div>
          </div>
          <% }) %>
      </div>
    </div>
  </section>

  <!-- JOIN CTA -->
  <section class="cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="section-title gold">Become a Member</h2>
      <p style="color:rgba(255,255,255,0.7);max-width:500px;margin:0 auto 28px;line-height:1.7;">Join Amba Bhavani
        Marata Mandali and be part of a proud, united community. Together we celebrate our heritage and serve our
        people.</p>
      <a href="/join" class="btn-primary large">Volunteer With Us</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-logo">
        <div class="nav-logo-icon small">ABM</div>
        <span>Amba Bhavani Marata Mandali</span>
      </div>
      <p class="footer-tagline">Jai Bhavani &nbsp;·&nbsp; Jai Shivaji </p>
      <div style="margin: 16px 0;">
        <a href="https://www.instagram.com/abmm_bengaluru?utm_source=qr&igsh=MTRjZnJ1emk3Mm1oNg==" target="_blank"
          rel="noopener noreferrer"
          style="display:inline-flex;align-items:center;gap:8px;color:#f5c842;text-decoration:none;font-weight:500;padding:8px 16px;border:1px solid rgba(245,200,66,0.3);border-radius:24px;transition:all 0.3s ease;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          Follow us on Instagram
        </a>
      </div>
      <p class="footer-copy">© 2026 Amba Bhavani Marata Mandali. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>

</html>